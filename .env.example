OPENAI_API_KEY=sk-...

# Directory where repos are cloned. Defaults to /tmp/repo-onboarding-agent/repos
CLONE_BASE_DIR=/tmp/repo-onboarding-agent/repos

# Max reflection iterations before forcing synthesis. Default: 8
MAX_ITERATIONS=8

# LLM model overrides (cloud mode, used when LOCAL_LLM_BASE_URL is not set).
# For data collection, set SUMMARY_MODEL=gpt-4o to use gpt-4o for all calls.
REASONING_MODEL=gpt-4o
SUMMARY_MODEL=gpt-4o-mini

# Local model mode - routes all LLM calls to a local Ollama server.
# One-time setup: bash fine_tuning/fuse_and_convert.sh
# Start the server: bash fine_tuning/serve.sh
# Then set this to enable fully local, zero-cost inference.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=repo-onboarding-qwen
